# Mongo
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>

# Server
PORT=8000
FRONTEND_URL=http://localhost:5173
# Preferred for Stripe redirect URLs
FRONTEND_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Auth (REQUIRED for stable tokens)
JWT_SECRET=change-me
JWT_EXPIRES_IN_SECONDS=604800

# Mira tokens (REQUIRED for stable QR verification across restarts)
TOKEN_HMAC_SECRET=change-me
PUBLIC_WEB_BASE_URL=http://localhost:5173

# Ops / Telemetry (optional)
# Used to hash IP addresses in scan_events (privacy). Set this for stable hashes across restarts.
SCAN_IP_HASH_SALT=

# Dev seeding (optional; used by scripts/seed_dev.py)
SEED_EMAIL=dev@example.com
SEED_PASSWORD=password123
SEED_CLAIMS=0
SEED_SCANS_PER_CLAIM=0

# Stripe (Stage-1 paywall)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# One-time credit top-ups
STRIPE_PRICE_ID_1000=price_...
STRIPE_PRICE_ID_5000=price_...
STRIPE_PRICE_ID_12000=price_...

# Legacy (optional)
STRIPE_PRICE_ID=price_...
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel

# Support chat model provider: "anthropic" (Claude) or "groq" (open-source
# models like Llama via Groq's OpenAI-compatible API). The SSE contract is
# identical either way — flip this with no code change.
CHAT_PROVIDER=anthropic

# Anthropic — used when CHAT_PROVIDER=anthropic (optional in dev; without a
# key the bot returns an "I'm having trouble connecting" fallback)
ANTHROPIC_API_KEY=sk-ant-...

# Groq — used when CHAT_PROVIDER=groq. Get a key at https://console.groq.com.
# GROQ_MODEL accepts any model Groq serves; the default is their strongest
# open-source tool-use model. Other options: llama-3.1-8b-instant (faster/
# cheaper), openai/gpt-oss-120b (higher quality). Without a key the bot
# returns the same offline fallback as a missing Anthropic key.
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Chat rate limits (defaults shown). Per signed-in user (authed) and per
# remote IP (anon). Sliding window in seconds.
CHAT_RATE_LIMIT_AUTHED=20
CHAT_RATE_LIMIT_ANON=10
CHAT_RATE_WINDOW_S=60

# SendGrid — used to email ticket owners when an admin replies or closes
# their ticket. If SENDGRID_API_KEY is blank the service degrades to
# log-only mode (admin requests still succeed; no email sent).
# - SENDGRID_FROM_EMAIL must be verified in the SendGrid console (single
#   sender or domain-authenticated). An unverified address gets 403'd.
# - SUPPORT_REPLY_TO should be a monitored inbox that funnels into the
#   ticket pipeline.
SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=support@miratrust.ai
SENDGRID_FROM_NAME=MiraTrust Support
SUPPORT_REPLY_TO=support@miratrust.ai
